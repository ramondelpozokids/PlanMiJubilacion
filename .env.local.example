# ============ SUPABASE ============
# Proyecto NUEVO recomendado — ver supabase/SETUP.md
# Sustituye estos 3 valores tras crear planmijubilacion en supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Contraseña de Postgres (solo para npm run db:push — Settings → Database)
SUPABASE_DB_PASSWORD=
# Opcional: connection string completa si el host directo no funciona
# SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.REF.supabase.co:5432/postgres

# ============ FACTURACIÓN (opcional) ============
BILLING_LEGAL_NAME=
BILLING_TAX_ID=
BILLING_ADDRESS=
BILLING_EMAIL=info@ramondelpozorott.es
BILLING_PHONE=

# ============ OPENAI ============
OPENAI_API_KEY=

# ============ GOOGLE ============
GEMINI_API_KEY=
GOOGLE_PROJECT_ID=planmijubilacion
GOOGLE_LOCATION=eu
GOOGLE_PROCESSOR_ID=
# Opcional: meta verification Search Console (si no usas el HTML en /public)
# GOOGLE_SITE_VERIFICATION=

# ============ STRIPE (opcional) ============
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=

# ============ POSTHOG (opcional) ============
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ============ SENTRY (opcional) ============
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=planmijubilacion
SENTRY_PROJECT=web
SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_FILE_WARNING=1

# ============ APP ============
# Producción (Vercel): https://plan-mi-jubilacion.vercel.app  (o tu dominio .es)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============ CONTACTO (cifrado adjuntos) ============
# Clave maestra para envolver las claves AES de los PDF cifrados en el navegador.
# Genera una cadena larga aleatoria (mín. 32 caracteres) y guárdala solo en Vercel/.env.local
# IMPORTANTE: la misma clave debe estar en Vercel Production o no se podrán descifrar adjuntos.
CONTACT_FILE_SECRET=
# Bandeja / notificaciones de contacto (fundador)
CONTACT_NOTIFY_EMAIL=info@ramondelpozorott.es

# ============ ADMIN / FUNDADOR ============
# info@ramondelpozorott.es + ramon55555@gmail.com — lib/admin/config.ts
